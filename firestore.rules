rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Resultados de evaluaciones CCVD: registro append-only.
    // Cualquiera puede leer (admin ve todo) y crear (registrar su evaluación),
    // pero nadie puede modificar ni borrar → historial permanente y a prueba de manipulación.
    match /resultados_ccvd/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Cuentas de usuario CCVD: para que el mismo login funcione en cualquier
    // computador o teléfono. Sin Firebase Auth no se puede distinguir al admin
    // por reglas, así que lectura/escritura quedan abiertas; las contraseñas se
    // guardan cifradas (hash SHA-256) y nunca en texto plano.
    match /usuarios_ccvd/{doc} {
      allow read, write: if true;
    }
  }
}
